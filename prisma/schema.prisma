// Gymify Database Schema
// Using SQLite for local dev — swap to PostgreSQL for production

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]

  profile           Profile?
  plans             WorkoutPlan[]
  sessionsData      WorkoutSession[]
  measurements      Measurement[]
  userAchievements  UserAchievement[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  age          Int
  gender       String   // male | female | other
  height       Float    // cm
  weight       Float    // kg
  fitnessLevel String   // beginner | intermediate | advanced
  goal         String   // lose-fat | build-muscle | stay-healthy | get-stronger
  daysPerWeek  Int
  equipment    String   // bodyweight | dumbbells | full-gym
  injuries     String   @default("")

  updatedAt    DateTime @updatedAt
}

model WorkoutPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  split       String
  daysJson    String   // JSON array of TrainingDay objects
  generatedAt DateTime @default(now())

  @@index([userId])
}

model WorkoutSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  exercise  String
  reps      Int
  avgScore  Float
  duration  Int      // seconds
  side      String
  scoresJson String  // JSON array of score numbers
  date      DateTime @default(now())

  @@index([userId])
  @@index([date])
}

model Measurement {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date    DateTime @default(now())
  weight  Float    // kg
  bodyFat Float?   // %
  chest   Float?   // cm
  waist   Float?   // cm
  arms    Float?   // cm
  thighs  Float?   // cm

  @@index([userId])
  @@index([date])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  icon        String   // Emoji or icon name
  condition   String   // JSON string or specific code identifier like 'FIRST_WORKOUT'
  
  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}
