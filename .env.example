# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite (keep provider="sqlite" in schema.prisma for local)
# Production: copy your Neon / Supabase connection string here
DATABASE_URL="file:./dev.db"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Set to your production domain on Vercel, e.g. https://gymify.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers ───────────────────────────────────────────────────────────
# GitHub OAuth App — https://github.com/settings/developers
GITHUB_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"

# Google OAuth App — https://console.cloud.google.com/apis/credentials
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

# ─── AI / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
